/* --- GLOBAL THEME --- */
Screen {
    background: #111111;
    color: #00ff00;
}

/* --- HEADER & FOOTER --- */
Header {
    background: #003300;
    color: #00ff00;
    dock: top;
    height: 1;
}

Footer {
    background: #003300;
    color: #00ff00;
    dock: bottom;
    height: 1;
}

/* --- SIDEBAR --- */
#sidebar {
    dock: left;
    width: 25;
    height: 100%;
    background: #0a0a0a;
    border-right: solid #005500;
}

.sidebar-title {
    text-align: center;
    padding: 1;
    color: #00ff00;
    text-style: bold;
    background: #002200;
    margin-bottom: 1;
}

Button {
    width: 100%;
    margin: 0;
    margin-bottom: 1;
    background: #1a1a1a;
    color: #888888;
    border: none;
    height: 3;
}

Button:hover {
    background: #004400;
    color: #ffffff;
}

Button.-active {
    background: #006600;
    color: #ffffff;
    text-style: bold;
}

/* --- DASHBOARD --- */
.stat-card {
    width: 1fr;
    height: 10;
    background: #0f1f0f;
    border: solid #005500;
    margin: 1;
    padding: 1;
    content-align: center middle;
}

.stat-value {
    text-style: bold;
    color: #00ff00;
}

.stat-label {
    color: #88aa88;
}

/* --- LIBRARY VIEW --- */
#library-container {
    layout: horizontal;
    height: 100%;
}

#model-list {
    width: 60%;
    height: 100%;
    border-right: solid #005500;
}

#model-details {
    width: 40%;
    height: 100%;
    padding: 1;
    background: #0a0a0a;
}

.details-title {
    text-style: bold;
    color: #00ff00;
    border-bottom: solid #005500;
    margin-bottom: 1;
}

/* --- DATATABLE --- */
DataTable {
    background: #111111;
    border: none;
}

DataTable > .datatable--header {
    background: #002200;
    color: #00ff00;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #004400;
    color: #ffffff;
}

/* --- OLLAMA MANAGER --- */
#ollama-status {
    height: 3;
    background: #001100;
    border: solid #005500;
    margin-bottom: 1;
    content-align: center middle;
}

.status-online {
    color: #00ff00;
    text-style: bold;
}

.status-offline {
    color: #ff0000;
    text-style: bold;
}